{
  "ConnectionStrings": {
    "DefaultConnection": "Server=${DB_HOST:postgres};Port=${DB_PORT:5432};Database=evento_prd_db;User Id=${DB_USER:postgres};Password=${DB_PASSWORD:postgres};"
  },
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Expiration": 86400000
  },
  "Cors": {
    "AllowedOrigins": [
      "https://memuvie.vercel.app",
      "http://localhost:4200",
      "http://localhost:3000"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.EntityFrameworkCore": "Error",
      "Microsoft.AspNetCore.Security": "Warning"
    }
  },
  "AllowedHosts": "memuvie-backend.onrender.com;localhost;*",
  "Seed": {
    "CreateAdminUser": false
  },
  "Cloudinary": {
    "CloudName": "${CLOUDINARY_CLOUD_NAME}",
    "ApiKey": "${CLOUDINARY_API_KEY}",
    "ApiSecret": "${CLOUDINARY_API_SECRET}"
  },
  "Mail": {
    "Host": "${MAIL_HOST:smtp.gmail.com}",
    "Port": "${MAIL_PORT:587}",
    "Username": "${MAIL_USERNAME}",
    "Password": "${MAIL_PASSWORD}",
    "EnableSSL": true,
    "UseStartTls": true,
    "From": "${MAIL_FROM}",
    "DisplayName": "Memuvie",
    "Providers": {
      "Gmail": {
        "Host": "smtp.gmail.com",
        "Port": 587,
        "RequiresAuth": true,
        "UseStartTls": true
      },
      "Outlook": {
        "Host": "smtp.office365.com",
        "Port": 587,
        "RequiresAuth": true,
        "UseStartTls": true
      },
      "iCloud": {
        "Host": "smtp.mail.me.com",
        "Port": 587,
        "RequiresAuth": true,
        "UseStartTls": true
      }
    },
    "Timeouts": {
      "ConnectionTimeoutMs": 10000,
      "TimeoutMs": 10000,
      "WriteTimeoutMs": 10000
    },
    "SmtpSettings": {
      "Auth": true,
      "SslTrust": "*"
    }
  },
  "App": {
    "FrontendUrl": "${FRONTEND_URL:https://seu-dominio.com}",
    "PasswordReset": {
      "TokenValidityMinutes": 30,
      "Link": "/redefinir-senha"
    }
  }
}
